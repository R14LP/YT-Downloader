{
  "manifest_version": 3,
  "name": "Grabber Helper",
  "version": "1.5",
  "description": "Send downloads to Grabber app",
  "permissions": [
    "activeTab",
    "storage",
    "nativeMessaging"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_title": "Grabber"
  }
}