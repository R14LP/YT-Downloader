{
  "manifest_version": 2,
  "name": "Grabber Helper",
  "version": "1.3",
  "description": "Send downloads to Grabber app",
  "permissions": [
    "activeTab",
    "storage",
    "downloads",
    "cookies",
    "nativeMessaging",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "browser_action": {
    "default_title": "Grabber"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "grab@r14lp",
      "strict_min_version": "58.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
