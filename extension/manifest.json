{
  "manifest_version": 2,
  "name": "Grabber Helper",
  "version": "1.1",
  "description": "Send downloads to Grabber app",
  "permissions": ["activeTab", "storage", "downloads", "cookies", "nativeMessaging", "<all_urls>"],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Grabber"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "grab@r14lp"
    }
  },
  "data_collection_permissions": "no_data_collected"
}
